# Build output
build/bin/
/ditherbench
/ditherforge
/ditherforge-cli
/debug-render

# Frontend
frontend/node_modules/
frontend/dist/
frontend/package.json.md5
frontend/vite.config.js
frontend/vite.config.d.ts

# Output files
*.3mf
*.obj
*.mtl
*.ply

# Generated PNG renders. We deliberately do NOT use a blanket *.png ignore,
# so checked-in images (images/, build/appicon.png, tests/testdata/color/*.png)
# need no force-adding. Instead ignore the directories that hold generated
# renders by path. tests/output/ also self-ignores via its own .gitignore.
tests/output/*.png
internal/voxel/testdata/sticker-renders/*.png

# Test cache (remesh outputs keyed by source hash)
tests/cache/

# Local scripts. devscripts/ is its own Go submodule (see
# devscripts/go.mod) so the parent's `go mod tidy` and `wails dev`
# skip it regardless of what scripts a developer has laid down.
# Pattern is devscripts/* (not devscripts/) so the un-ignore for
# go.mod/go.sum below can take effect — git won't re-include
# anything beneath a fully-ignored directory.
devscripts/*
!devscripts/go.mod
!devscripts/go.sum

# Claude Code harness runtime files
.claude/scheduled_tasks.lock
.claude/agent-memory/
.claude/projects/
